getgenv().Start = true

spawn(function()
    while wait() and Start do
        pcall(function()
            for i,v in pairs(game:GetService("ReplicatedStorage").Resources.IceSkating.GingerbreadMarkers:GetChildren()) do
                if v:IsA("BasePart") then
                    game:GetService("ReplicatedStorage").API:FindFirstChild("WinterEventAPI/PickUpGingerbread"):InvokeServer(v.Name)
                end 
            end 
            game:GetService("ReplicatedStorage").API:FindFirstChild("WinterEventAPI/RedeemPendingGingerbread"):FireServer()
        end)
    end
end)

local vu = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:connect(function()
   vu:Button2Down(Vector2.new(0,0),workspace.CurrentCamera.CFrame)
   wait(1)
   vu:Button2Up(Vector2.new(0,0),workspace.CurrentCamera.CFrame)
end)


