        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(1840.58, 405.431, 979.824)
        wait(0.5)
        input.hold(Enum.KeyCode.E, 3)
        print("energy checked")
        wait(70)
    else
        if workspace.Delivery.TakeOrderZone.Part.Transparency == 0.5 then
            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = workspace.Delivery.TakeOrderZone.Part.CFrame
            input.hold(Enum.KeyCode.W, 0.4)
            wait(0.3)
            attemps = attemps + 1
            print(attemps.." failsave")
            if attemps >= 5 then
                input.hold(Enum.KeyCode.E, 3)
                attemps = attemps * 0
            end
